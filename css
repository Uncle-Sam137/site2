.tarry-ca-button {
    cursor: pointer;
}

.tarry-ca-button .elementor-button-text {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
}

.tarry-ca-text {
    white-space: nowrap;
    word-break: normal;
    overflow-wrap: normal;
}

.tarry-ca-button.copied::after {
    content: "Copied";
    position: absolute;
    top: -32px;
    left: 50%;
    transform: translateX(-50%);
    background: #111;
    color: #fff;
    font-size: 12px;
    padding: 4px 8px;
    border-radius: 6px;
    line-height: 1;
}

.tarry-ca-button {
    position: relative;
}

.tarry-ca-button {
    position: relative;
    cursor: pointer;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
}

.tarry-ca-button::-webkit-scrollbar {
    display: none;
}

.tarry-ca-button .elementor-button-content-wrapper {
    display: block;
    width: 100%;
}

.tarry-ca-button .elementor-button-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    letter-spacing: 0 !important;
    word-spacing: 0 !important;
    text-transform: none !important;
    justify-content: center;
}

.tarry-ca-text {
    display: inline-block;
    white-space: nowrap !important;
    word-break: keep-all !important;
    overflow-wrap: normal !important;
    letter-spacing: 0 !important;
    word-spacing: 0 !important;
    text-transform: none !important;
    font-kerning: none;
    font-variant-ligatures: none;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 14px;
    line-height: 1.2;
}

.tarry-ca-button.copied::after {
    content: "Copied";
    position: absolute;
    left: 50%;
    top: -34px;
    transform: translateX(-50%);
    background: #111;
    color: #fff;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 12px;
    line-height: 1;
    white-space: nowrap;
    z-index: 20;
    pointer-events: none;
}

@media (max-width: 767px) {
    .tarry-ca-text {
        font-size: 12px;
    }
}